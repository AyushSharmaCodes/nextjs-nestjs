{
  "compilerOptions": {
    "target": "es2022",
    "module": "node16",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "typeRoots": [
      "../merigaumata/node_modules/@types",
      "../backend-microservices/node_modules/@types"
    ],
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
