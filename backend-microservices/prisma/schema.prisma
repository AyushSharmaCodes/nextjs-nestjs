generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app_auth", "app_user"]
}

model User {
  id               String   @id @default(uuid())
  firstName        String?
  lastName         String?
  email            String   @unique
  emailVerified    Boolean  @default(false)
  twoFactorEnabled Boolean  @default(false)
  image            String?
  role             String   @default("CUSTOMER")
  gender           String?
  dob              DateTime?
  nationality      String?
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  securityEvents  SecurityEvent[]   @relation("UserSecurityEvents")
  otpEmailHistory OTPEmailHistory[] @relation("UserOtpHistory")
  twoFactor       TwoFactor?
  deviceSessions  DeviceSession[]   @relation("UserDeviceSessions")
  roleRelation    Role              @relation(fields: [role], references: [name], onDelete: Restrict)
  profile         Profile?

  @@index([role])
  @@map("user")
  @@schema("app_auth")
}

model Session {
  id                String   @id @default(uuid())
  expiresAt         DateTime
  token             String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ipAddress         String?
  userAgent         String?
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  twoFactorVerified Boolean?

  @@index([userId])
  @@map("session")
  @@schema("app_auth")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
  @@schema("app_auth")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
  @@map("verification")
  @@schema("app_auth")
}

model TwoFactor {
  id          String   @id @default(uuid())
  userId      String   @unique
  secret      String
  backupCodes String[]
  verified    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factors")
  @@schema("app_auth")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  permissions RolePermission[]
  users       User[]
  profiles    Profile[]        @relation("ProfileRole")

  @@map("roles")
  @@schema("app_auth")
}

model Permission {
  id          String   @id @default(uuid())
  action      String
  resource    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
  @@schema("app_auth")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
  @@schema("app_auth")
}

model SecurityEvent {
  id            String   @id @default(uuid())
  userId        String?
  email         String?
  eventType     String
  status        String
  ipAddress     String?
  userAgent     String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User?    @relation("UserSecurityEvents", fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("security_events")
  @@schema("app_auth")
}

model OTPEmailHistory {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  subject   String
  body      String
  status    String
  createdAt DateTime @default(now())
  user      User?    @relation("UserOtpHistory", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("otp_email_history")
  @@schema("app_auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// Communication module: Email Audit
// ─────────────────────────────────────────────────────────────────────────────

/**
 * EmailAudit records every email send attempt with full lifecycle tracking.
 * - eventId is the idempotency key (UUID v4 from the auth event payload).
 * Unique constraint prevents double-processing of replayed events.
 * - status flows: PENDING → SENT | FAILED | SKIPPED
 * - requestId links the audit record back to the originating HTTP request
 * for distributed tracing.
 */
model EmailAudit {
  id                String      @id @default(uuid())
  eventId           String      @unique // idempotency key — UUID v4 from event payload
  eventName         String // AUTH_EVENTS constant string
  userId            String
  toEmail           String
  status            EmailStatus
  providerMessageId String? // Resend ID / SES MessageId / null on FAILED
  failReason        String? // populated on FAILED status
  requestId         String // trace ID from originating HTTP request
  sentAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([eventName, createdAt])
  @@map("email_audit")
  @@schema("app_auth")
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@schema("app_auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth module: Suspicious Session Detection
// ─────────────────────────────────────────────────────────────────────────────

/**
 * DeviceSession is a WRITE-ONCE security audit record per sign-in.
 * Architecture: This is NOT a session store. It does NOT participate
 * in auth validation. The JWT signature is the only thing verified per request.
 * - betterAuthSessionId: FK to Better Auth's session.id (for BA revocation)
 * - sessionId: = BA session.token (= JWT sessionId claim), used as correlation ID
 * - Written once at sign-in. Never updated (isActive/liveness = owned by BA)
 * - queried at the NEXT sign-in to compare history for anomaly detection
 */
model DeviceSession {
  id                  String           @id @default(uuid())
  userId              String
  betterAuthSessionId String           @unique // BA session.id (for revocation calls)
  sessionId           String           @unique // BA session.token = JWT sessionId claim
  ipAddress           String
  city                String?
  region              String?
  country             String // ISO 3166-1 alpha-2 (or 'XX' for unknown)
  latitude            Float?
  longitude           Float?
  isp                 String?
  deviceType          DeviceType
  os                  String
  osVersion           String
  browser             String
  browserVersion      String
  fingerprint         String // SHA-256(ua + os + osVersion + browser)
  isTrusted           Boolean          @default(false)
  trustGrantedAt      DateTime?
  riskLevel           SessionRiskLevel
  suspicionReasons    String[]
  createdAt           DateTime         @default(now()) // = sign-in time
  updatedAt           DateTime         @updatedAt

  user User @relation("UserDeviceSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, fingerprint])
  @@index([userId, ipAddress])
  @@map("device_sessions")
  @@schema("app_auth")
}

/**
 * SuspiciousSessionAudit records every flagged session with full context
 * for compliance review, user self-service, and admin tooling.
 * - eventId is the idempotency key matching the emitted auth event.
 * - resolvedAt/resolvedBy/resolution track the lifecycle of a flag.
 */
model SuspiciousSessionAudit {
  id               String           @id @default(uuid())
  deviceSessionId  String
  userId           String
  eventId          String           @unique // idempotency — matches auth event
  riskLevel        SessionRiskLevel
  suspicionReasons String[]
  ipAddress        String
  country          String
  fingerprint      String
  resolvedAt       DateTime?
  resolvedBy       String? // 'user' | 'admin' | 'system'
  resolution       AuditResolution?
  emailSentAt      DateTime?
  requestId        String
  createdAt        DateTime         @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([deviceSessionId])
  @@map("suspicious_session_audits")
  @@schema("app_auth")
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN

  @@schema("app_auth")
}

enum SessionRiskLevel {
  NORMAL
  SUSPICIOUS
  HIGH_RISK

  @@schema("app_auth")
}

enum AuditResolution {
  CONFIRMED_BY_USER // user clicked "This was me"
  REVOKED_BY_USER // user clicked "This wasn't me"
  AUTO_REVOKED // system revoked on HIGH_RISK
  EXPIRED // audit record aged out

  @@schema("app_auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// User Module
// ─────────────────────────────────────────────────────────────────────────────

model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String
  role        Role      @relation("ProfileRole", fields: [roleId], references: [id], onDelete: Restrict)
  firstName   String?
  lastName    String?
  locale      String    @default("en")
  timezone    String    @default("UTC")
  isActive    Boolean   @default(true)
  isVerified  Boolean   @default(false)
  avatarUrl   String?
  coverUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  phoneNumbers              UserPhoneNumber[]
  addresses                 UserAddress[]
  managerPermissionGrants   ManagerPermissionGrant[] @relation("ManagerGrants")
  adminPermissionGrants     ManagerPermissionGrant[] @relation("AdminGrants")
  adminActivityLogs         AdminActivityLog[]       @relation("AdminLogs")
  targetManagerActivityLogs AdminActivityLog[]       @relation("TargetManagerLogs")
  actorAuditLogs            AuditLog[]               @relation("ActorAuditLogs")
  
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
  @@map("profiles")
  @@schema("app_user")
}

model UserPhoneNumber {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  number    String
  label     String   @default("MOBILE") // MOBILE, HOME, WORK, etc.
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_phone_numbers")
  @@schema("app_user")
}

model UserAddress {
  id         String       @id @default(uuid())
  profileId  String
  profile    Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label      String       @default("HOME") // HOME, WORK, OTHER
  line1      String
  line2      String?
  city       String
  state      String
  countryCode String      @db.Char(2)
  postalCode String
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  @@map("user_addresses")
  @@schema("app_user")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actor     Profile? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  targetId  String?
  action    String
  payload   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_log")
  @@schema("app_user")
}

model ManagerPermissionDefinition {
  id              String   @id @default(uuid())
  slug            String   @unique
  resource        String
  action          String
  labelI18n       String
  descriptionI18n String
  isDangerous     Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  grants          ManagerPermissionGrant[]

  @@unique([resource, action])
  @@map("manager_permission_definitions")
  @@schema("app_user")
}

model ManagerPermissionGrant {
  id                  String   @id @default(uuid())
  managerProfileId    String
  managerProfile      Profile  @relation("ManagerGrants", fields: [managerProfileId], references: [id], onDelete: Cascade)
  permissionId        String
  permission          ManagerPermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByAdminId    String
  grantedByAdmin      Profile  @relation("AdminGrants", fields: [grantedByAdminId], references: [id], onDelete: Restrict)
  grantedAt           DateTime @default(now())
  expiresAt           DateTime?
  isActive            Boolean  @default(true)
  revokedAt           DateTime?
  revokedByAdminId    String?

  @@unique([managerProfileId, permissionId])
  @@index([managerProfileId, isActive])
  @@index([expiresAt])
  @@map("manager_permission_grants")
  @@schema("app_user")
}

model AdminActivityLog {
  id                String   @id @default(uuid())
  adminProfileId    String
  adminProfile      Profile  @relation("AdminLogs", fields: [adminProfileId], references: [id], onDelete: Restrict)
  actionType        String
  targetManagerId   String
  targetManager     Profile  @relation("TargetManagerLogs", fields: [targetManagerId], references: [id], onDelete: Restrict)
  permissionSlug    String?
  note              String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())

  @@index([adminProfileId, createdAt(sort: Desc)])
  @@index([targetManagerId, createdAt(sort: Desc)])
  @@map("admin_activity_log")
  @@schema("app_user")
}
