# ============================================
# MERIGAUMATA API — Environment Configuration
# Modular Monolith (Single Deployment)
# ============================================

NODE_ENV=development
PORT=3000

# ============================================
# DATABASE (Supabase / Local Postgres)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=merigaumata
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2

# ============================================
# REDIS (BullMQ queues)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://:password@host:6379

# ============================================
# JWT (RS256)
# ============================================
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=auth-service-v1

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# RAZORPAY (Payments)
# ============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================================
# AWS (Email via SES)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL_MS=900000
THROTTLE_LIMIT=1000
THROTTLE_AUTH_TTL_MS=900000
THROTTLE_AUTH_LIMIT=20