<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><title>Your 2FA Code</title></head>
<body style="margin:0;padding:0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background:#f9fafb;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;padding:40px 0;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.08);">
        <tr><td style="background:linear-gradient(135deg,#0ea5e9,#0284c7);padding:32px 40px;text-align:center;">
          <h1 style="margin:0;color:#ffffff;font-size:26px;font-weight:700;">🛡 Two-Factor Authentication</h1>
        </td></tr>
        <tr><td style="padding:40px;text-align:center;">
          <p style="color:#374151;line-height:1.7;margin:0 0 28px;text-align:left;">Your two-factor authentication code for MeriGauMata login{{#if deviceHint}} (device: <strong>...{{deviceHint}}</strong>){{/if}}:</p>
          <div style="background:#f0f9ff;border-radius:12px;padding:28px;margin:0 0 28px;">
            <span style="font-size:42px;font-weight:700;letter-spacing:10px;color:#0284c7;font-family:monospace;">{{totpCode}}</span>
          </div>
          <p style="color:#6b7280;font-size:13px;line-height:1.6;text-align:left;">⏰ Expires at: <strong>{{expiresAt}}</strong><br/>🔒 Do not share this code. MeriGauMata will never ask for it.</p>
        </td></tr>
        <tr><td style="background:#f9fafb;padding:20px 40px;text-align:center;border-top:1px solid #e5e7eb;">
          <p style="margin:0;color:#9ca3af;font-size:12px;">© {{year}} MeriGauMata. All rights reserved.</p>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
